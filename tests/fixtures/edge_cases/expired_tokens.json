{
  "description": "Expired JWT tokens for testing token expiration and refresh scenarios",
  "jwt_algorithm": "HS256",
  "test_secret": "test_jwt_secret_key_for_testing_only_12345",
  "expired_access_tokens": [
    {
      "name": "Access token expired 1 hour ago",
      "payload": {
        "sub": "1",
        "username": "admin",
        "role": "owner",
        "permissions": ["*"],
        "type": "access",
        "exp": 1700000000,
        "iat": 1699996600
      },
      "expected_error": "Token has expired",
      "error_code": 401,
      "notes": "Standard expired access token"
    },
    {
      "name": "Access token expired 1 day ago",
      "payload": {
        "sub": "2",
        "username": "manager",
        "role": "marketer",
        "permissions": ["dashboard.read", "customer.read"],
        "type": "access",
        "exp": 1699910000,
        "iat": 1699823600
      },
      "expected_error": "Token has expired",
      "error_code": 401
    },
    {
      "name": "Access token expired 1 week ago",
      "payload": {
        "sub": "3",
        "username": "operator",
        "role": "operator",
        "permissions": ["dashboard.read", "pos.sale"],
        "type": "access",
        "exp": 1699300000,
        "iat": 1699823600
      },
      "expected_error": "Token has expired",
      "error_code": 401
    }
  ],
  "expired_refresh_tokens": [
    {
      "name": "Refresh token expired 1 day ago",
      "payload": {
        "sub": "1",
        "type": "refresh",
        "exp": 1699910000,
        "iat": 1699823600
      },
      "expected_error": "Token has expired",
      "error_code": 401,
      "notes": "Refresh tokens have 7 day expiry, this one is past that"
    },
    {
      "name": "Refresh token expired 1 week ago",
      "payload": {
        "sub": "2",
        "type": "refresh",
        "exp": 1699300000,
        "iat": 1699216400
      },
      "expected_error": "Token has expired",
      "error_code": 401
    }
  ],
  "invalid_token_types": [
    {
      "name": "Access token with refresh type",
      "payload": {
        "sub": "1",
        "username": "admin",
        "role": "owner",
        "type": "refresh",
        "exp": 2000000000,
        "iat": 1700000000
      },
      "expected_error": "Invalid token type",
      "error_code": 401,
      "notes": "Using refresh token as access token"
    },
    {
      "name": "Refresh token with access type",
      "payload": {
        "sub": "1",
        "type": "access",
        "exp": 2000000000,
        "iat": 1700000000
      },
      "expected_error": "Invalid token type",
      "error_code": 401,
      "notes": "Using access token as refresh token"
    }
  ],
  "malformed_tokens": [
    {
      "name": "Invalid signature",
      "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxIiwidXNlcm5hbWUiOiJhZG1pbiIsInJvbGUiOiJvd25lciIsInBlcm1pc3Npb25zIjpbIioiXSwidHlwZSI6ImFjY2VzcyIsImV4cCI6MjAwMDAwMDAwMCwiaWF0IjoxNzAwMDAwMDAwfQ.invalid_signature",
      "expected_error": "Invalid token",
      "error_code": 401
    },
    {
      "name": "Empty token",
      "token": "",
      "expected_error": "Token is required",
      "error_code": 401
    },
    {
      "name": "Invalid JSON payload",
      "token": "not.a.valid.jwt.token",
      "expected_error": "Invalid token",
      "error_code": 401
    },
    {
      "name": "Missing payload",
      "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..signature",
      "expected_error": "Invalid token",
      "error_code": 401
    }
  ],
  "wrong_user_tokens": [
    {
      "name": "Token for different user",
      "payload": {
        "sub": "999",
        "username": "hacker",
        "role": "owner",
        "permissions": ["*"],
        "type": "access",
        "exp": 2000000000,
        "iat": 1700000000
      },
      "notes": "Valid token but user doesn't exist in system"
    },
    {
      "name": "Token with deleted user ID",
      "payload": {
        "sub": "99999",
        "username": "deleted_user",
        "role": "operator",
        "permissions": ["dashboard.read"],
        "type": "access",
        "exp": 2000000000,
        "iat": 1700000000
      },
      "notes": "Valid token structure but user was deleted from database"
    }
  ],
  "edge_cases": [
    {
      "name": "Token with missing sub",
      "payload": {
        "username": "admin",
        "role": "owner",
        "type": "access",
        "exp": 2000000000,
        "iat": 1700000000
      },
      "expected_error": "Invalid token payload",
      "error_code": 401
    },
    {
      "name": "Token with missing role",
      "payload": {
        "sub": "1",
        "username": "admin",
        "type": "access",
        "exp": 2000000000,
        "iat": 1700000000
      },
      "notes": "Token valid but no role specified"
    },
    {
      "name": "Token with future iat",
      "payload": {
        "sub": "1",
        "username": "admin",
        "role": "owner",
        "type": "access",
        "exp": 2000000000,
        "iat": 3000000000
      },
      "notes": "Token issued in the future - possible manipulation"
    },
    {
      "name": "Token with very old iat",
      "payload": {
        "sub": "1",
        "username": "admin",
        "role": "owner",
        "type": "access",
        "exp": 2000000000,
        "iat": 1000000000
      },
      "notes": "Token issued very long ago but still valid expiry"
    }
  ],
  "refresh_scenario": {
    "description": "Complete refresh token flow test data",
    "valid_access_token": {
      "payload": {
        "sub": "1",
        "username": "admin",
        "role": "owner",
        "permissions": ["*"],
        "type": "access",
        "exp": 2000000000,
        "iat": 1700000000
      }
    },
    "expired_access_token": {
      "payload": {
        "sub": "1",
        "username": "admin",
        "role": "owner",
        "permissions": ["*"],
        "type": "access",
        "exp": 1700000000,
        "iat": 1699996600
      }
    },
    "valid_refresh_token": {
      "payload": {
        "sub": "1",
        "type": "refresh",
        "exp": 2000000000,
        "iat": 1700000000
      }
    },
    "expired_refresh_token": {
      "payload": {
        "sub": "1",
        "type": "refresh",
        "exp": 1699910000,
        "iat": 1699823600
      }
    }
  }
}
