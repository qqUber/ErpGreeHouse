{
  "description": "Supported locales configuration for the ERP GreenHouse system",
  "default_locale": "ru",
  "supported_locales": [
    {
      "code": "ru",
      "name": "Russian",
      "native_name": "Русский",
      "language_code": "ru-RU",
      "date_format": "DD.MM.YYYY",
      "time_format": "HH:mm",
      "datetime_format": "DD.MM.YYYY HH:mm",
      "currency": "RUB",
      "currency_symbol": "₽",
      "number_format": {
        "decimal_separator": ",",
        "thousands_separator": " ",
        "decimal_digits": 2
      },
      "translations_file": "ru.json",
      "is_rtl": false,
      "is_default": true
    },
    {
      "code": "en",
      "name": "English",
      "native_name": "English",
      "language_code": "en-US",
      "date_format": "MM/DD/YYYY",
      "time_format": "h:mm A",
      "datetime_format": "MM/DD/YYYY h:mm A",
      "currency": "USD",
      "currency_symbol": "$",
      "number_format": {
        "decimal_separator": ".",
        "thousands_separator": ",",
        "decimal_digits": 2
      },
      "translations_file": "en.json",
      "is_rtl": false,
      "is_default": false
    },
    {
      "code": "srb",
      "name": "Serbian",
      "native_name": "Српски",
      "language_code": "sr-RS",
      "date_format": "DD.MM.YYYY",
      "time_format": "HH:mm",
      "datetime_format": "DD.MM.YYYY HH:mm",
      "currency": "RSD",
      "currency_symbol": "дин",
      "number_format": {
        "decimal_separator": ",",
        "thousands_separator": ".",
        "decimal_digits": 2
      },
      "translations_file": "srb.json",
      "is_rtl": false,
      "is_default": false
    }
  ],
  "fallback_locale": "en",
  "locale_detection_order": [
    "cookie",
    "header",
    "query_param",
    "session",
    "browser"
  ],
  "query_param_name": "lang",
  "cookie_name": "locale",
  "header_name": "Accept-Language",
  "ui_labels": {
    "ru": {
      "language_switcher": "Язык",
      "current_language": "Русский"
    },
    "en": {
      "language_switcher": "Language",
      "current_language": "English"
    },
    "srb": {
      "language_switcher": "Језик",
      "current_language": "Српски"
    }
  },
  "test_scenarios": [
    {
      "scenario": "Default locale",
      "expected_code": "ru"
    },
    {
      "scenario": "Query parameter override",
      "input": "?lang=en",
      "expected_code": "en"
    },
    {
      "scenario": "Invalid locale code",
      "input": "?lang=xx",
      "expected_code": "ru",
      "fallback": true
    },
    {
      "scenario": "Missing locale",
      "input": "?lang=",
      "expected_code": "ru",
      "fallback": true
    }
  ]
}
