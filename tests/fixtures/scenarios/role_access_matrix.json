  "test_scenarios": {
    "unauthorized_access": {
      "description": "Test that unauthorized users cannot access protected endpoints",
      "scenarios": [
        {
          "endpoint": "/customers",
          "method": "POST",
          "role": "observer",
          "expected_status": 403
        },
        {
          "endpoint": "/products",
          "method": "POST",
          "role": "operator",
          "expected_status": 403
        },
        {
          "endpoint": "/settings",
          "method": "GET",
          "role": "marketer",
          "expected_status": 403
        }
      ]
    },
    "anonymous_access": {
      "description": "Test that only specific endpoints allow anonymous access",
      "scenarios": [
        {
          "endpoint": "/auth/login",
          "method": "POST",
          "role": null,
          "expected_status": 200
        },
        {
          "endpoint": "/dashboard",
          "method": "GET",
          "role": null,
          "expected_status": 401
        },
        {
          "endpoint": "/integrations/telegram/webhook",
          "method": "POST",
          "role": null,
          "expected_status": 200
        }
      ]
    },
    "role_escalation": {
      "description": "Test that users cannot access endpoints outside their role",
      "scenarios": [
        {
          "endpoint": "/settings/users",
          "method": "POST",
          "role": "marketer",
          "expected_status": 403
        },
        {
          "endpoint": "/marketing/campaigns",
          "method": "POST",
          "role": "operator",
          "expected_status": 403
        }
      ]
    }
  }
