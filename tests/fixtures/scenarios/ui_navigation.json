{
  "description": "UI navigation test scenarios for the ERP GreenHouse admin panel",
  "base_url": "/",
  "login_page": {
    "path": "/",
    "title": "ERP Greenhouse - Admin Panel",
    "elements": {
      "username_input": {
        "selector": "input[placeholder*='Логин'], input[name='username']",
        "label": "Логин"
      },
      "password_input": {
        "selector": "input[placeholder*='Пароль'], input[name='password']",
        "label": "Пароль"
      },
      "login_button": {
        "selector": "button:has-text('Войти')",
        "label": "Войти"
      },
      "error_message": {
        "selector": ".error, [role='alert']",
        "label": "Сообщение об ошибке"
      }
    }
  },
  "navigation_menu": {
    "items": [
      {
        "id": "dashboard",
        "label_ru": "Сводка",
        "label_en": "Dashboard",
        "path": "/",
        "icon": "dashboard",
        "visible_to": ["owner", "marketer", "operator", "observer"]
      },
      {
        "id": "sales",
        "label_ru": "Операции",
        "label_en": "Operations",
        "path": "/sales",
        "icon": "point_of_sale",
        "visible_to": ["owner", "operator"]
      },
      {
        "id": "clients",
        "label_ru": "Клиенты",
        "label_en": "Clients",
        "path": "/clients",
        "icon": "people",
        "visible_to": ["owner", "marketer", "operator"]
      },
      {
        "id": "products",
        "label_ru": "Товары",
        "label_en": "Products",
        "path": "/products",
        "icon": "inventory",
        "visible_to": ["owner", "marketer"]
      },
      {
        "id": "marketing",
        "label_ru": "Маркетинг",
        "label_en": "Marketing",
        "path": "/marketing",
        "icon": "campaign",
        "visible_to": ["owner", "marketer"]
      },
      {
        "id": "integrations",
        "label_ru": "Интеграции",
        "label_en": "Integrations",
        "path": "/integrations",
        "icon": "settings_input_component",
        "visible_to": ["owner", "marketer"]
      },
      {
        "id": "settings",
        "label_ru": "Настройки",
        "label_en": "Settings",
        "path": "/settings",
        "icon": "settings",
        "visible_to": ["owner"]
      }
    ]
  },
  "role_navigation_tests": {
    "owner": {
      "allowed_pages": [
        "dashboard",
        "sales",
        "clients",
        "products",
        "marketing",
        "integrations",
        "settings"
      ],
      "test_scenarios": [
        {
          "scenario": "Full menu access",
          "steps": [
            "Login as admin",
            "Verify all menu items are visible",
            "Click each menu item",
            "Verify page loads successfully"
          ]
        },
        {
          "scenario": "Settings access",
          "steps": [
            "Navigate to Settings",
            "Verify 'Настройки доступа' is visible",
            "Verify user management is accessible"
          ]
        }
      ]
    },
    "marketer": {
      "allowed_pages": [
        "dashboard",
        "clients",
        "products",
        "marketing",
        "integrations"
      ],
      "test_scenarios": [
        {
          "scenario": "Limited menu access",
          "steps": [
            "Login as manager",
            "Verify 'Операции' is NOT visible",
            "Verify 'Настройки' is NOT visible"
          ]
        },
        {
          "scenario": "Marketing access",
          "steps": [
            "Navigate to Marketing",
            "Verify campaigns section is accessible",
            "Verify create campaign button is visible"
          ]
        },
        {
          "scenario": "Product management",
          "steps": [
            "Navigate to Products",
            "Verify create product button is visible",
            "Verify import products button is visible"
          ]
        }
      ]
    },
    "operator": {
      "allowed_pages": [
        "dashboard",
        "sales"
      ],
      "test_scenarios": [
        {
          "scenario": "Minimal menu access",
          "steps": [
            "Login as operator",
            "Verify only Dashboard and Operations are visible"
          ]
        },
        {
          "scenario": "POS sale flow",
          "steps": [
            "Navigate to Operations",
            "Verify customer identification field is visible",
            "Verify product catalog is accessible"
          ]
        },
        {
          "scenario": "No sensitive access",
          "steps": [
            "Try to access Settings directly",
            "Verify 403 Forbidden or redirect to Dashboard"
          ]
        }
      ]
    },
    "observer": {
      "allowed_pages": [
        "dashboard"
      ],
      "test_scenarios": [
        {
          "scenario": "Read-only access",
          "steps": [
            "Login as observer",
            "Verify only Dashboard is visible",
            "Verify no create/edit buttons are visible"
          ]
        }
      ]
    }
  },
  "page_test_scenarios": {
    "dashboard": {
      "path": "/",
      "elements": [
        {
          "id": "title",
          "selector": "h1:has-text('Сводка')",
          "required": true
        },
        {
          "id": "stats_cards",
          "selector": ".stats-card, [class*='card']",
          "min_count": 3
        }
      ],
      "tests": [
        {
          "name": "Dashboard loads with stats",
          "verify": ["Title visible", "Stats cards present"]
        },
        {
          "name": "Dashboard data refresh",
          "action": "Click refresh button",
          "verify": ["Data updates", "Loading indicator appears"]
        }
      ]
    },
    "sales_operations": {
      "path": "/sales",
      "elements": [
        {
          "id": "customer_search",
          "selector": "input[placeholder*='телефон']",
          "required": true
        },
        {
          "id": "identify_button",
          "selector": "button:has-text('Идентифицировать')",
          "required": true
        },
        {
          "id": "product_catalog",
          "selector": "select, combobox",
          "required": true
        },
        {
          "id": "cart_table",
          "selector": "table",
          "required": false
        },
        {
          "id": "submit_button",
          "selector": "button:has-text('Провести')",
          "required": true
        }
      ],
      "tests": [
        {
          "name": "Customer identification",
          "steps": [
            "Enter phone number",
            "Click identify button",
            "Verify customer info appears"
          ]
        },
        {
          "name": "Add product to cart",
          "steps": [
            "Select product",
            "Click add to cart",
            "Verify product in cart table"
          ]
        },
        {
          "name": "Process sale with bonus",
          "steps": [
            "Identify customer",
            "Add product",
            "Enter bonus amount",
            "Click провести",
            "Verify success message"
          ]
        }
      ]
    },
    "clients": {
      "path": "/clients",
      "elements": [
        {
          "id": "search_input",
          "selector": "input[placeholder*='Поиск']",
          "required": true
        },
        {
          "id": "new_client_button",
          "selector": "button:has-text('Новый клиент')",
          "required": false
        },
        {
          "id": "clients_table",
          "selector": "table",
          "required": true
        }
      ],
      "tests": [
        {
          "name": "Search customer by phone",
          "steps": [
            "Enter phone number",
            "Click search",
            "Verify results appear"
          ]
        },
        {
          "name": "Create new client",
          "steps": [
            "Click 'Новый клиент'",
            "Fill form fields",
            "Click create",
            "Verify success"
          ]
        }
      ]
    },
    "products": {
      "path": "/products",
      "elements": [
        {
          "id": "create_product_button",
          "selector": "button:has-text('Добавить товар')",
          "required": false
        },
        {
          "id": "import_button",
          "selector": "button:has-text('Импорт')",
          "required": false
        },
        {
          "id": "products_table",
          "selector": "table",
          "required": true
        }
      ],
      "tests": [
        {
          "name": "Product list loads",
          "verify": ["Products table visible", "Products displayed"]
        },
        {
          "name": "Import products",
          "steps": [
            "Click import button",
            "Upload CSV/Excel file",
            "Verify import progress",
            "Verify success message"
          ]
        }
      ]
    },
    "marketing": {
      "path": "/marketing",
      "elements": [
        {
          "id": "campaigns_section",
          "selector": "h2:has-text('Кампании')",
          "required": true
        },
        {
          "id": "create_campaign_button",
          "selector": "button:has-text('Создать кампанию')",
          "required": false
        }
      ],
      "tests": [
        {
          "name": "View campaigns",
          "verify": ["Campaigns list visible"]
        },
        {
          "name": "Create campaign",
          "steps": [
            "Click create campaign",
            "Fill campaign details",
            "Set dates",
            "Save",
            "Verify campaign created"
          ]
        }
      ]
    },
    "integrations": {
      "path": "/integrations",
      "elements": [
        {
          "id": "telegram_section",
          "selector": "h2:has-text('Telegram')",
          "required": true
        },
        {
          "id": "vk_section",
          "selector": "h2:has-text('VK')",
          "required": true
        },
        {
          "id": "webhooks_section",
          "selector": "h2:has-text('Webhooks')",
          "required": true
        }
      ],
      "tests": [
        {
          "name": "View integrations",
          "verify": ["All integration sections visible"]
        },
        {
          "name": "Configure Telegram",
          "steps": [
            "Find Telegram settings",
            "Enter bot token",
            "Save",
            "Verify success"
          ]
        }
      ]
    },
    "settings": {
      "path": "/settings",
      "elements": [
        {
          "id": "access_settings",
          "selector": "h2:has-text('Настройки доступа')",
          "required": true
        },
        {
          "id": "roles_table",
          "selector": "table:has-text('Роль')",
          "required": true
        }
      ],
      "tests": [
        {
          "name": "Access control page",
          "verify": ["Roles table visible", "Permissions displayed"]
        },
        {
          "name": "Modify role permissions",
          "steps": [
            "Find role row",
            "Change permission",
            "Save",
            "Verify update"
          ]
        }
      ]
    }
  },
  "common_navigation_tests": [
    {
      "scenario": "Session persistence",
      "description": "Verify user stays logged in after page reload",
      "steps": [
        "Login",
        "Navigate to any page",
        "Reload page",
        "Verify still authenticated"
      ]
    },
    {
      "scenario": "Logout flow",
      "description": "Verify logout clears session",
      "steps": [
        "Login",
        "Click logout button",
        "Verify redirected to login",
        "Try to access protected page",
        "Verify redirect to login"
      ]
    },
    {
      "scenario": "Language switch",
      "description": "Verify language switching works",
      "steps": [
        "Click language switcher",
        "Select different language",
        "Verify UI text changes",
        "Reload page",
        "Verify language persists"
      ]
    },
    {
      "scenario": "Unauthorized access redirect",
      "description": "Verify unauthorized access redirects to appropriate page",
      "steps": [
        "Login as operator",
        "Try to access /settings",
        "Verify redirect to allowed page",
        "Login as observer",
        "Try to access /sales",
        "Verify redirect"
      ]
    },
    {
      "scenario": "Breadcrumb navigation",
      "description": "Verify breadcrumbs work correctly",
      "steps": [
        "Navigate to nested page",
        "Click breadcrumb item",
        "Verify navigation to that page"
      ]
    }
  ],
  "responsive_tests": {
    "breakpoints": [
      {
        "name": "Mobile",
        "width": 375,
        "height": 667,
        "menu_behavior": "hamburger_menu"
      },
      {
        "name": "Tablet",
        "width": 768,
        "height": 1024,
        "menu_behavior": "collapsible"
      },
      {
        "name": "Desktop",
        "width": 1280,
        "height": 800,
        "menu_behavior": "always_visible"
      }
    ]
  }
}
