# Qwen Companion MCP Environment Variables
# Copy this file to .env.qwen and fill in your secrets
# DO NOT commit .env.qwen to version control

# =============================================================================
# MCP Server Configuration
# =============================================================================

# GitHub MCP Server
# Get your token from: https://github.com/settings/tokens
# Required scopes: repo, read:user, user:email
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_YOUR_TOKEN_HERE

# =============================================================================
# Project Environment Variables (Reference)
# =============================================================================

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# ERPNext Configuration
ERP_API_BASE_URL=https://your-erpnext.com
ERP_API_KEY=your_api_key
ERP_API_SECRET=your_api_secret
ERP_MOCK_MODE=true

# Database Configuration
DATABASE_URL=postgresql://user:pass@localhost/telegram_crm
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET_KEY=your_jwt_secret
WEBHOOK_SECRET=your_webhook_secret
ADMIN_SECRET=your_admin_secret
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=ChangeMe123!
ADMIN_RECOVERY_SECRET=your_recovery_secret

# Performance tuning
CACHE_TTL=3600
MAX_CONCURRENT_REQUESTS=100
RATE_LIMIT_PER_MINUTE=60

# Feature Flags
DEBUG_MODE=true
TEST_MODE=false
MOCK_MODE=true
ENABLE_RATE_LIMITING=true
ENABLE_JWT_AUTH=true
LOG_REQUESTS=true
