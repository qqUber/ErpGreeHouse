# Production Environment Configuration for ErpGreeHouse
# This file contains production-specific configuration options.
# Copy this file to .env and update with your actual values.

# ============================================================================
# Basic Configuration
# ============================================================================
ENVIRONMENT=production
DEBUG_MODE=false
TEST_MODE=false

# ============================================================================
# JWT Configuration (CRITICAL for production)
# ============================================================================
# Generate a secure random secret key (e.g., openssl rand -hex 32)
JWT_SECRET_KEY=your-secure-jwt-secret-key-here

# JWT algorithm (HS256 is recommended)
JWT_ALGORITHM=HS256

# JWT token expiration times (security best practices)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================================
# Telegram Bot Configuration
# ============================================================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ============================================================================
# VK (VKontakte) Bot Configuration
# ============================================================================
VK_ACCESS_TOKEN=your-vk-access-token-here
VK_GROUP_ID=your-vk-group-id-here
VK_API_VERSION=5.131

# ============================================================================
# ERPNext Integration Configuration
# ============================================================================
ERP_API_BASE_URL=http://erpnext:8000
ERP_API_KEY=your-erp-api-key-here
ERP_API_SECRET=your-erp-api-secret-here

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_NAME=telegram_crm
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://redis-queue:6379/1

# ============================================================================
# Web Configuration
# ============================================================================
BASE_WEB_URL=https://yourdomain.com
WEBHOOK_SECRET=your-webhook-secret-here

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
# Password recovery rate limits
RECOVERY_RATE_LIMIT_ATTEMPTS=5
RECOVERY_RATE_LIMIT_WINDOW_SECONDS=60

# API rate limits (sliding window algorithm)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Telegram messaging rate limits
TELEGRAM_RATE_LIMIT_PER_CHAT=1.0
TELEGRAM_RATE_LIMIT_GLOBAL=30.0

# VK messaging rate limits
VK_RATE_LIMIT_PER_CHAT=1.0
VK_RATE_LIMIT_GLOBAL=0.333

# Mobile app messaging rate limits
MOBILE_RATE_LIMIT_PER_CHAT=5.0
MOBILE_RATE_LIMIT_GLOBAL=100.0

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# Compliance Configuration (152-FZ)
# ============================================================================
# Data localization settings (must be hosted within Russian Federation borders)
# This is enforced by production infrastructure configuration
# For more information, see docs/compliance/data_storage_compliance.md

# ============================================================================
# ERP Integration Configuration
# ============================================================================
ERP_MOCK_MODE=false
