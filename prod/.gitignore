# Production Environment - Git Ignore
# Исключаем секреты и временные файлы из production каталога

# Environment files with secrets
.env
.env.local
.env.*.local

# SSL Certificates (должны монтироваться отдельно)
ssl/*.pem
ssl/*.crt
ssl/*.key
ssl/*.p12

# Logs
logs/
*.log

# Database files (для SQLite если используется локально)
*.db
*.db-journal
*.sqlite
*.sqlite3

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Receipts and user data (должны храниться в volumes)
receipts/
data/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/
