{
  "name": "coffee-crm-admin-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check --write .",
    "ci:check": "biome check .",
    "clean": "rm -rf node_modules dist .turbo",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run --config vite.config.test.ts",
    "test:unit:watch": "vitest --config vite.config.test.ts",
    "test:unit:ui": "vitest --config vite.config.test.ts --ui",
    "test:unit:coverage": "vitest run --config vite.config.test.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:critical": "playwright test --project=critical",
    "test:e2e:manual": "E2E_UI_MODE=manual E2E_PAUSE=1 playwright test --project=smoke --workers=1",
    "report:allure": "allure generate allure-results --clean -o allure-report",
    "screenshot": "node scripts/screenshot/capture.cjs",
    "screenshot:compare": "node scripts/screenshot/capture.cjs --compare --json screenshot-report.json",
    "screenshot:baseline": "node scripts/screenshot/capture.cjs --update-baseline",
    "screenshot:parallel": "node scripts/screenshot/capture.cjs --parallel 4",
    "screenshot:docker": "./scripts/docker-screenshot/run.sh",
    "ngrok:backend": "dotenv -e ../.env -- node scripts/ngrok/backend.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.5",
    "@ngrok/ngrok": "^1.5.1",
    "@twa-dev/sdk": "^8.0.2",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "node-fetch": "^3.3.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^1.4.4",
    "react-i18next": "^16.5.4",
    "react-modern-drawer": "^1.4.0",
    "react-qr-code": "^2.0.18",
    "react-refresh": "^0.18.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^25.3.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "allure-commandline": "^2.37.0",
    "allure-playwright": "^3.6.0",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^25.0.1",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
