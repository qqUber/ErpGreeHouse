# ERP GreenHouse - Environment Variables Template
# Copy this file to .env.dev or .env.e2e and customize as needed

# Environment
ENVIRONMENT=development
DEBUG_MODE=true
E2E_TEST_MODE=false

# Database & Cache
CRM_DB_PATH=/app/data/dev.db
DATABASE_URL=sqlite:///app/data/dev.db
REDIS_URL=redis://redis:6379/0

# Admin Authentication
ADMIN_SECRET=dev-admin-secret
E2E_ADMIN_SECRET=test-secret-key
ADMIN_BOOTSTRAP_DEFAULT=true
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin
ADMIN_RECOVERY_SECRET=dev-recovery-secret

# JWT Authentication
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABCDEF-DEV-TOKEN
TELEGRAM_CHANNEL_ID=-100123456789

# URLs
BASE_WEB_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

# ERP Integration
ERP_SYNC_ENABLED=true
ERP_MOCK_MODE=true
ERP_API_BASE_URL=http://mock-erp:8000

# Frontend/Backend Communication
VITE_API_BASE_URL=http://backend:8000
