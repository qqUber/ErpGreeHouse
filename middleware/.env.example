# ERP GreenHouse Environment Configuration
# Copy this file to .env and fill in the values

# Database
CRM_DB_PATH=

# Redis
REDIS_URL=redis://localhost:6379/0

# Admin Authentication
ADMIN_SECRET=
ADMIN_BOOTSTRAP_DEFAULT=true
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=
ADMIN_RECOVERY_SECRET=

# JWT Authentication (REQUIRED in production)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_CHANNEL_ID=

# VK Configuration
VK_ACCESS_TOKEN=
VK_GROUP_ID=
VK_API_VERSION=5.131

# ERP Integration
ERP_SYNC_ENABLED=false
ERP_API_BASE_URL=
ERP_API_KEY=
ERP_API_SECRET=

# Webhooks
WEBHOOK_SECRET=

# URLs
BASE_WEB_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

# Demo Sale (for testing loyalty points)
DEMO_SALE_AMOUNT=350

# Environment
ENVIRONMENT=development
DEBUG_MODE=true

# Rate Limiting (sliding window algorithm)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RECOVERY_RATE_LIMIT_ATTEMPTS=5
RECOVERY_RATE_LIMIT_WINDOW_SECONDS=60
