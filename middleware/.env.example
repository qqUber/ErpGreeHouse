# ERP GreenHouse Environment Configuration

# ===========================================
# Telegram Bot Configuration
# ===========================================

# Bot token from @BotFather (required)
# Get from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Webhook URL for receiving updates (optional for polling mode)
# Format: https://your-domain.com/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_URL=

# Channel/Group ID for notifications (optional)
# Use username (@channel) or numeric ID (-1001234567890)
TELEGRAM_CHANNEL_ID=

# ===========================================
# Redis Configuration
# ===========================================

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Redis host (alternative to URL)
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis database number
REDIS_DB=0

# ===========================================
# ERPNext Configuration
# ===========================================

# Enable mock mode for development (no real ERPNext connection)
# Set to 'false' for production with real ERPNext
ERP_MOCK_MODE=true

# ERPNext API base URL (production)
ERP_API_BASE_URL=https://erp.example.com

# ERPNext API credentials (production)
ERP_API_KEY=
ERP_API_SECRET=

# ===========================================
# Admin UI Authentication
# ===========================================

# Default admin credentials (change in production!)
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin

# JWT secret for token generation
JWT_SECRET=change-this-secret-in-production

# Token expiration (seconds)
JWT_EXPIRATION=86400

# ===========================================
# Database Configuration
# ===========================================

# SQLite for development
DATABASE_URL=sqlite:///./local/crm.db

# PostgreSQL for production (uncomment and configure)
# DATABASE_URL=postgresql://user:password@localhost:5432/erp_greenhouse

# ===========================================
# Application Settings
# ===========================================

# Web server configuration
HOST=127.0.0.1
PORT=8000

# Environment (development, staging, production)
ENVIRONMENT=development

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable request logging
REQUEST_LOGGING=true

# ===========================================
# Rate Limiting
# ===========================================

# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Default rate limit (requests per second)
RATE_LIMIT_DEFAULT=10

# Rate limit for authentication endpoints
RATE_LIMIT_AUTH=5

# Rate limit for API endpoints
RATE_LIMIT_API=30

# ===========================================
# File Storage
# ===========================================

# Directory for uploaded files
UPLOAD_DIR=./uploads

# Directory for generated PDFs
PDF_DIR=./receipts

# Maximum file size (bytes)
MAX_FILE_SIZE=10485760

# ===========================================
# Email Configuration (optional)
# ===========================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ===========================================
# Monitoring & Observability
# ===========================================

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Enable Prometheus metrics
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ===========================================
# Feature Flags
# ===========================================

# Enable/disable features
FEATURE_TELEGRAM_BOT=true
FEATURE_ADMIN_UI=true
FEATURE_API=true
FEATURE_CELERY_WORKER=false
