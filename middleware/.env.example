# Telegram CRM MVP Environment Configuration
# Copy this file to .env and fill in your values

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
TELEGRAM_ADMIN_IDS=123456789,987654321  # Comma-separated admin user IDs

# ERPNext Integration
ERP_API_BASE_URL=https://your-erpnext-instance.com
ERP_API_KEY=your_erpnext_api_key
ERP_API_SECRET=your_erpnext_api_secret
ERP_MOCK_MODE=true  # Set to false for production with real ERPNext

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/telegram_crm
REDIS_URL=redis://localhost:6379/0

# Security Settings
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
WEBHOOK_SECRET=your-webhook-secret-for-telegram-validation
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Application Settings
DEBUG_MODE=true
TEST_MODE=false
LOG_LEVEL=INFO
LOG_REQUESTS=true

# Performance Tuning
CACHE_TTL=3600
MAX_CONCURRENT_REQUESTS=100
RATE_LIMIT_PER_MINUTE=60
REQUEST_TIMEOUT=30

# Feature Flags
ENABLE_RATE_LIMITING=true
ENABLE_JWT_AUTH=true
ENABLE_METRICS=true
ENABLE_AUDIT_LOG=true

# 152-FZ Compliance (Russian Data Protection)
DATA_RETENTION_DAYS=2555  # 7 years
CONSENT_REQUIRED=true
DATA_ANONYMIZATION=true

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4

# Monitoring and Alerts
SENTRY_DSN=your-sentry-dsn-here  # Optional
METRICS_PORT=9090
HEALTH_CHECK_PORT=8080

# Development Settings
MOCK_ERPNEXT_RESPONSES=true
SIMULATE_SLOW_NETWORK=false
DEBUG_SQL_QUERIES=false

# Админ-доступ
# Вариант A: быстрый доступ через env-секрет (x-admin-secret)
ADMIN_SECRET=change-me

# Вариант B: доступ по логину/паролю (для dev)
ADMIN_BOOTSTRAP_DEFAULT=true
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=ChangeMe123!
ADMIN_RECOVERY_SECRET=RecoverMe123!
ADMIN_TOKEN_TTL_MIN=720
ADMIN_PBKDF2_ITER=200000

CORS_ORIGINS=http://localhost:5173,http://localhost:5174
CRM_DB_PATH=crm.db
RECEIPTS_DIR=receipts
ERP_SYNC_ENABLED=false
