# ERP GreenHouse Environment Configuration
# Copy this file to .env and fill in the values

# Database
CRM_DB_PATH=

# Redis
REDIS_URL=redis://localhost:6379/0

# Admin Authentication
ADMIN_SECRET=
ADMIN_BOOTSTRAP_DEFAULT=true
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=
ADMIN_RECOVERY_SECRET=

# JWT Authentication (REQUIRED in production)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ERP Integration
ERP_SYNC_ENABLED=false
ERP_API_BASE_URL=
ERP_API_KEY=
ERP_API_SECRET=

# Webhooks
WEBHOOK_SECRET=

# URLs
BASE_WEB_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

# Environment
ENVIRONMENT=development
DEBUG_MODE=true
