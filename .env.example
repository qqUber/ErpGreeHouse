# Environment Configuration
ENVIRONMENT=development
DEBUG_MODE=true

# Database Configuration
DATABASE_URL=sqlite:///app/data/dev.db
CRM_DB_PATH=/app/data/dev.db
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Admin Authentication
ADMIN_SECRET=dev-admin-secret
ADMIN_BOOTSTRAP_DEFAULT=true
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin
ADMIN_RECOVERY_SECRET=dev-recovery-secret

# Telegram Integration
TELEGRAM_BOT_TOKEN=123456789:ABCDEF-DEV-TOKEN
TELEGRAM_CHANNEL_ID=-100123456789
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# ERPNext Integration
ERP_API_BASE_URL=https://your-erpnext.com
ERP_API_KEY=your_api_key
ERP_API_SECRET=your_api_secret
ERP_MOCK_MODE=true
ERP_SYNC_ENABLED=true

# Application URLs
BASE_WEB_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://backend:8000

# E2E Testing
E2E_TEST_MODE=false
E2E_BASE_URL=http://localhost:5173
E2E_API_BASE_URL=http://localhost:8000
E2E_ADMIN_SECRET=test-secret-key

# Feature Flags
TEST_MODE=false
MOCK_MODE=true
ENABLE_RATE_LIMITING=true
ENABLE_JWT_AUTH=true
LOG_REQUESTS=true

# Performance Tuning
CACHE_TTL=3600
MAX_CONCURRENT_REQUESTS=100
RATE_LIMIT_PER_MINUTE=60

# Security
WEBHOOK_SECRET=your_webhook_secret
NGROK_AUTHTOKEN=